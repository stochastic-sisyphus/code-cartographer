# Allowlist approach - ignore everything by default
*

# Then explicitly allow what we want to track
!.gitignore
!.github/
!.github/**
!code_cartographer/
!code_cartographer/**
!tests/
!tests/**
!examples/
!examples/**
!docs/
!docs/**
!web/
!web/**

# Project files
!pyproject.toml
!README.md
!LICENSE
!MANIFEST.in
!setup.py
!.mise.toml
!.python-version

# Scripts
!*.sh

# Keep CLAUDE.md ignored (not in allowlist)
# Keep these ignored
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.venv/
venv/
.coverage
.pytest_cache/
htmlcov/
.DS_Store
*.swp
*.swo
