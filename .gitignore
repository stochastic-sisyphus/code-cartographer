# Allowlist approach - ignore everything by default
*
*/

# Explicitly allow tracked directories and their contents
!.github/
!.github/**
!code_cartographer/
!code_cartographer/**
!tests/
!tests/**
!examples/
!examples/**
!docs/
!docs/**
!web/
!web/**

# Explicitly allow project files
!.gitignore
!pyproject.toml
!README.md
!LICENSE
!.mise.toml
!*.sh

# Standard ignores (override allowlist for these)
__pycache__/
*.py[cod]
*.so
build/
dist/
*.egg-info/
.venv/
.coverage
.pytest_cache/
.DS_Store
